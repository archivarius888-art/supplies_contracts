{
  "name": "@spro/supplies-contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Shared contracts for frontend and backend",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
